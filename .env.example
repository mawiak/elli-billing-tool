# Elli account credentials
ELLI_EMAIL=your.email@example.com
ELLI_PASSWORD=your_password

# Charging station and RFID card IDs
# Run 'python -m elli_billing_tool.cli list' to find these values
ELLI_STATION_ID=your_station_id
ELLI_RFID_CARD_ID=your_rfid_card_id

# Price per kWh in cents (e.g., 30 for 0.30 EUR)
ELLI_KWH_PRICE_CENTS=30

# Location for signature (e.g., Sankt Ingbert)
ELLI_LOCATION=Sankt Ingbert

# Email configuration
# Subject can use placeholders: {MONTH}, {YEAR}, {NAME}
EMAIL_SUBJECT=Energiekostenabrechnung {MONTH} {YEAR}
# Comma-separated list of recipients
EMAIL_RECIPIENTS=fibu@example.com,accounting@example.com
# Comma-separated list of CC recipients (optional)
EMAIL_CC=manager@example.com
# Your name for email signature
EMAIL_NAME=Marc Szymkowiak
